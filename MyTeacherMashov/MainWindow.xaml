<Window x:Class="MyTeacherMashov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyTeacherMashov"
        mc:Ignorable="d"
        Title="Teacher Login" 
        Height="600" 
        Width="500" 
        MinHeight="450"
        MinWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FlowDirection="LeftToRight">

    <Viewbox Stretch="Uniform" Margin="20">
        <Border Width="340" 
                Background="White" 
                CornerRadius="15" 
                Padding="25"
                BorderBrush="#E0E6ED"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#D3D9E2" Direction="270" ShadowDepth="5" Opacity="0.7"/>
            </Border.Effect>

            <StackPanel>
                <Ellipse Width="60" Height="60" Fill="#1E88E5" HorizontalAlignment="Center" Margin="0,10,0,15">
                </Ellipse>

                <TextBlock Text="Teacher Login"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,5"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Sign in using your ID"
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="User ID" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,0,15">
                    <TextBox x:Name="txtUsername"
                             Height="36" 
                             Padding="8,0" 
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Foreground="#2C3E50"
                             GotFocus="txtUsername_GotFocus"
                             LostFocus="txtUsername_LostFocus"/>
                </Border>

                <TextBlock Text="Password" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,0,25">
                    <PasswordBox x:Name="pwPassword"
                                 Height="36" 
                                 Padding="8,0" 
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Foreground="#2C3E50"/>
                </Border>

                <Button x:Name="btnLogin"
                        Content="Login"
                        Background="#1E88E5"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        Height="42" 
                        Cursor="Hand"
                        Click="btnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1565C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Viewbox>
</Window>