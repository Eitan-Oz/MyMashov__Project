<Window x:Class="MyTeacherMashov.TeacherStudentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyTeacherMashov"
        mc:Ignorable="d"
        Title="My Students" 
        Height="600" 
        Width="700"
        MinHeight="450"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FlowDirection="LeftToRight">

    <Viewbox Stretch="Uniform" Margin="20">
        <Border Width="620" 
                Height="480"
                Background="White" 
                CornerRadius="15" 
                Padding="25"
                BorderBrush="#E0E6ED"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#D3D9E2" Direction="270" ShadowDepth="5" Opacity="0.7"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="My Students"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#2C3E50"/>
                    <TextBlock Text="View the list of students registered in your classes"
                               FontSize="13"
                               Foreground="#7F8C8D"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <DataGrid x:Name="dgStudents" 
                          Grid.Row="1"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EBF0F5"
                          RowHeight="40"
                          FontSize="14"
                          Foreground="#2C3E50">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#34495E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Student ID" Binding="{Binding PersonalID}" Width="120"/>
                        <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="130"/>
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="130"/>
                        <DataGridTextColumn Header="Phone Number" Binding="{Binding PhoneNumber}" Width="140"/>
                        <DataGridTextColumn Header="Class ID" Binding="{Binding ClassID}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Viewbox>
</Window>