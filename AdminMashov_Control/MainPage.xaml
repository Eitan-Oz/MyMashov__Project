<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AdminMashov_Control.MainPage"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="AdminCardStyle" TargetType="Border">
                <Setter Property="Stroke" Value="#2E2E2E" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="40" />
                <Setter Property="BackgroundColor" Value="#1E1E1E" />
                <Setter Property="WidthRequest" Value="380" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="TitleLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="SubtitleLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="#888888" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="LoginButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#007AFF" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HeightRequest" Value="45" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,10,0,0" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Border Style="{StaticResource AdminCardStyle}">
            <VerticalStackLayout Spacing="20">

                <Image Source="admin_shield.png" 
                       HeightRequest="50" 
                       HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="5">
                    <Label Text="Admin Portal" 
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="Please sign in to continue" 
                           Style="{StaticResource SubtitleLabelStyle}" />
                </VerticalStackLayout>

                <Button x:Name="LoginButton"
                        Text="Login"
                        Style="{StaticResource LoginButtonStyle}"
                        Clicked="OnLoginClicked" />

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>